# CultureShock Backend Configuration
# Copy to .env and fill in values.

# --- App ---
APP_NAME=CultureShock API
APP_VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1

# --- CORS (comma-separated origins; use * for dev only) ---
CORS_ORIGINS=["*"]

# --- Provider selection (real by default) ---
# Alert sources: multi (USGS+GDACS+NASA EONET+ReliefWeb) | usgs | mock
ALERT_PROVIDER=multi
TRANSPORT_PROVIDER=osm
AI_PROVIDER=azure_openai
NOTIFICATION_PROVIDER=mock

# --- Azure OpenAI (required when AI_PROVIDER=azure_openai) ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# --- Azure Communication Services (required when NOTIFICATION_PROVIDER=azure_sms) ---
AZURE_COMM_CONNECTION_STRING=
AZURE_COMM_FROM_NUMBER=

# --- Firebase (required for push notifications) ---
FIREBASE_CREDENTIALS_PATH=
